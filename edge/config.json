{
  "name": "HoyMiles Solar Gateway edge Addon",
  "version": "2.0.0",
  "slug": "hoymiles_solardata_edge",
  "description": "Read Hoymiles Gateway Solar Data edge Version.",
  "arch": [
    "armhf",
    "armv7",
    "aarch64",
    "amd64",
    "i386"
  ],
  "url": "https://github.com/dmslabsbr/hoymiles/tree/master/edge",
  "startup": "application",
  "boot": "auto",
  "init": false,
  "hassio_api": false,
  "homeassistant_api": false,
  "hassio_role": "default",
  "devicetree": false,
  "services": [
    "mqtt:need"
  ],
  "ingress": false,
  "ingress_port": 5000,
  "host_network": true,
  "panel_icon": "mdi:solar-power",
  "panel_title": "HoyMiles Solar Data Gateway edge version.",
  "panel_admin": false,
  "options": {
    "HOYMILES_USER": "HOYMILES_USER",
    "HOYMILES_PASSWORD": "HOYMILES_PASSWORD",
    "HOYMILES_PLANT_ID": "123",
    "USE_ESTAR": false,
    "EXPERIMENTAL_CUSTOM_API_URLS": false,
    "DEBUG_FORCE_API_VERSION": false,
    "External_MQTT_Server": false,
    "MQTT_TLS": false,
    "MQTT_TLS_PORT": 8883,
    "MQTT_DISCOVERY_PREFIX": "homeassistant",
    "MQTT_NODE_ID": "hoymiles",
    "HA_EXPIRE_TIME": 600,
    "GET_DATA_INTERVAL": 480,
    "HASS_INTERVAL": 300,
    "READ_METER_DATA": false,
    "Auto_update_token": false,
    "DEVELOPERS_MODE": false,
    "LOG_LEVEL": "INFO"
  },
  "schema": {
    "HOYMILES_USER": "str",
    "HOYMILES_PASSWORD": "password",
    "HOYMILES_PLANT_ID": "str",
    "USE_ESTAR": "bool?",
    "EXPERIMENTAL_CUSTOM_API_URLS": "bool?",
    "API_GATEWAY_BASE_URL": "str?",
    "API_VERSIONED_BASE_URL": "str?",
    "API_COOKIE_DOMAIN": "str?",
    "DEBUG_FORCE_API_VERSION": "bool",
    "DEBUG_API_VERSION": "list(0|3)?",
    "External_MQTT_Server": "bool",
    "MQTT_Host": "str?",
    "MQTT_User": "str?",
    "MQTT_Pass": "password?",
    "MQTT_TLS": "bool?",
    "MQTT_TLS_PORT": "port?",
    "MQTT_DISCOVERY_PREFIX": "str?",
    "MQTT_NODE_ID": "str?",
    "HA_EXPIRE_TIME": "int?",
    "GET_DATA_INTERVAL": "int?",
    "HASS_INTERVAL": "int?",
    "READ_METER_DATA": "bool?",
    "Auto_update_token": "bool",
    "DEVELOPERS_MODE": "bool",
    "LOG_LEVEL": "list(DEBUG|INFO|WARNING|ERROR|CRITICAL)?"
  }
}
